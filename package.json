{
  "name": "triocord-landing",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "clean": "if exist .next (rd /s /q .next)",
    "dev:clean": "npm run clean && next dev",
    "docker:prod": "docker compose up -d",
    "docker:prod:build": "docker compose up --build -d",
    "docker:dev": "docker compose -f docker-compose.dev.yml up",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml up --build"
  },
  "dependencies": {
    "next": "^16.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.1.0"
  }
}
